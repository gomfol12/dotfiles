# ==================== general hotkeys ====================
### starting programs ###
super + t
    $TERMINAL

shift + mod1 + Return
    $TERMINAL

super + c
	$BROWSER

super + l
	slockrun.sh

super + v
	/usr/bin/code

super + d
	/usr/bin/discord

super + k
	/usr/bin/keepassxc

super + b
	/usr/bin/lutris

super + e
	/usr/bin/nemo

super + m
	$TERMINAL -e "/home/$(whoami)/scripts/spt.sh"

super + s
	/usr/bin/steam

super + z
	/usr/bin/teams

super + o
	/usr/bin/thunderbird

super + i
    /usr/bin/libreoffice

### multimedia keys ###
XF86AudioStop
	killall spotifyd

XF86AudioNext
	playerctl --player spotifyd next

XF86AudioPrev
	playerctl --player spotifyd previous

XF86AudioPlay
	playerctl --player spotifyd play-pause

### util ###
# remove formating from copied text
ctrl + b
    xsel -b | xsel -b

mod1 + p
    clipmenu

super + w
    dmenu_websearch

Menu
	dmenu_run

Print
	screenshotter.sh

Pause
	switchCompositing.sh

Scroll_Lock
	switchAudioOutput.sh

super + n
    colorpicker --short --one-shot --preview | xsel -b

### restart ###
# make sxhkd reload its configuration files
super + shift + x
	pkill -USR1 -x sxhkd && notify-send "sxhkd" "Config reloaded"

super + shift + o
    ~/.config/polybar/launch.sh &

#super + shift + m
